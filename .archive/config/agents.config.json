{
  "version": "1.0.0",
  "description": "Central agent configuration — model assignments, retry limits, timeouts, and feature flags. Read from environment variables at runtime; this file provides defaults and documentation.",
  "agents": {
    "resume_intelligence": {
      "id": "agent-resume-intelligence",
      "name": "Resume Intelligence Agent",
      "version": "1.0.0",
      "workflow_name": "🧠 Agent: Resume Intelligence v1.0.0",
      "model": "${MODEL_RESUME_PARSING:-google/gemini-flash-1.5}",
      "fallback_model": "${MODEL_FALLBACK:-meta-llama/llama-3.1-8b-instruct}",
      "max_retries": 3,
      "retry_backoff_ms": 1000,
      "timeout_ms": 60000,
      "cache_key_pattern": "resume_profile:{resume_id}",
      "cache_ttl_seconds": 604800,
      "enabled": true,
      "phase": 3,
      "estimated_tokens": { "min": 1500, "max": 3000 }
    },
    "career_goal": {
      "id": "agent-career-goal",
      "name": "Career Goal Agent",
      "version": "1.0.0",
      "workflow_name": "🎯 Agent: Career Goal v1.0.0",
      "model": "${MODEL_CAREER_GOAL:-anthropic/claude-haiku-3}",
      "fallback_model": "${MODEL_FALLBACK:-meta-llama/llama-3.1-8b-instruct}",
      "max_retries": 3,
      "retry_backoff_ms": 1000,
      "timeout_ms": 30000,
      "cache_key_pattern": "career_goals:{user_id}:{resume_id}",
      "cache_ttl_seconds": 86400,
      "enabled": true,
      "phase": 3,
      "estimated_tokens": { "min": 500, "max": 1000 }
    },
    "job_search": {
      "id": "agent-job-search",
      "name": "Job Search Agent",
      "version": "1.0.0",
      "workflow_name": "🔍 Agent: Job Search v1.0.0",
      "model": null,
      "max_retries": 2,
      "retry_backoff_ms": 5000,
      "timeout_ms": 30000,
      "cache_key_pattern": "jobs:{user_id}:{query_hash}",
      "cache_ttl_seconds": 21600,
      "enabled": true,
      "phase": 3,
      "estimated_tokens": 0,
      "sources": ["serpapi", "adzuna", "rapidapi"]
    },
    "internship_search": {
      "id": "agent-internship-search",
      "name": "Internship Search Agent",
      "version": "1.0.0",
      "workflow_name": "🎓 Agent: Internship Search v1.0.0",
      "model": null,
      "max_retries": 2,
      "retry_backoff_ms": 5000,
      "timeout_ms": 30000,
      "cache_key_pattern": "internships:{user_id}:{query_hash}",
      "cache_ttl_seconds": 21600,
      "enabled": true,
      "phase": 3,
      "estimated_tokens": 0
    },
    "job_quality": {
      "id": "agent-job-quality",
      "name": "Job Quality Agent",
      "version": "1.0.0",
      "workflow_name": "⭐ Agent: Job Quality v1.0.0",
      "model": "${MODEL_JOB_QUALITY:-google/gemini-flash-1.5}",
      "fallback_model": "${MODEL_FALLBACK:-meta-llama/llama-3.1-8b-instruct}",
      "max_retries": 3,
      "retry_backoff_ms": 1000,
      "timeout_ms": 60000,
      "enabled": true,
      "phase": 4,
      "estimated_tokens": { "min": 2000, "max": 5000 }
    },
    "ghost_detection": {
      "id": "agent-ghost-detection",
      "name": "Ghost Job Detection Agent",
      "version": "1.0.0",
      "workflow_name": "👻 Agent: Ghost Job Detection v1.0.0",
      "model": "${MODEL_GHOST_DETECTION:-google/gemini-flash-1.5}",
      "fallback_model": "${MODEL_FALLBACK}",
      "ghost_score_threshold": "${PIPELINE_GHOST_THRESHOLD:-70}",
      "max_retries": 3,
      "timeout_ms": 60000,
      "enabled": true,
      "phase": 4,
      "estimated_tokens": { "min": 1000, "max": 2000 }
    },
    "scam_detection": {
      "id": "agent-scam-detection",
      "name": "Scam Detection Agent",
      "version": "1.0.0",
      "workflow_name": "⚠️ Agent: Scam Detection v1.0.0",
      "model": "${MODEL_SCAM_DETECTION:-anthropic/claude-haiku-3}",
      "fallback_model": "${MODEL_FALLBACK}",
      "scam_score_threshold": "${PIPELINE_SCAM_THRESHOLD:-70}",
      "max_retries": 3,
      "timeout_ms": 60000,
      "enabled": true,
      "phase": 4,
      "estimated_tokens": { "min": 1500, "max": 3000 }
    },
    "duplicate_detection": {
      "id": "agent-duplicate-detection",
      "name": "Duplicate Detection Agent",
      "version": "1.0.0",
      "workflow_name": "🔄 Agent: Duplicate Detection v1.0.0",
      "model": "${MODEL_EMBEDDING:-openai/text-embedding-3-small}",
      "similarity_threshold": 0.95,
      "max_retries": 2,
      "timeout_ms": 30000,
      "qdrant_collection": "${QDRANT_COLLECTION_JOBS:-jobs}",
      "enabled": true,
      "phase": 4,
      "estimated_tokens": { "min": 100, "max": 500 }
    },
    "company_analysis": {
      "id": "agent-company-analysis",
      "name": "Company Analysis Agent",
      "version": "1.0.0",
      "workflow_name": "🏢 Agent: Company Analysis v1.0.0",
      "model": "${MODEL_JOB_QUALITY:-google/gemini-flash-1.5}",
      "cache_key_pattern": "company:{company_name_hash}",
      "cache_ttl_seconds": 259200,
      "max_retries": 2,
      "timeout_ms": 45000,
      "enabled": true,
      "phase": 4,
      "estimated_tokens": { "min": 500, "max": 1000 }
    },
    "ats_matching": {
      "id": "agent-ats-matching",
      "name": "ATS Matching Agent",
      "version": "1.0.0",
      "workflow_name": "📊 Agent: ATS Matching v1.0.0",
      "model": "${MODEL_ATS_MATCHING:-google/gemini-flash-1.5}",
      "fallback_model": "${MODEL_FALLBACK}",
      "ats_score_threshold": "${PIPELINE_ATS_THRESHOLD:-60}",
      "cache_key_pattern": "ats:{resume_id}:{listing_id}",
      "cache_ttl_seconds": 86400,
      "max_retries": 3,
      "timeout_ms": 90000,
      "enabled": true,
      "phase": 4,
      "estimated_tokens": { "min": 3000, "max": 8000 }
    },
    "resume_refinement": {
      "id": "agent-resume-refinement",
      "name": "Resume Refinement Agent",
      "version": "1.0.0",
      "workflow_name": "✏️ Agent: Resume Refinement v1.0.0",
      "model": "${MODEL_RESUME_REFINEMENT:-anthropic/claude-3-5-sonnet}",
      "fallback_model": "${MODEL_JOB_QUALITY:-google/gemini-flash-1.5}",
      "max_retries": 2,
      "timeout_ms": 90000,
      "enabled": true,
      "phase": 5,
      "estimated_tokens": { "min": 2000, "max": 4000 }
    },
    "cover_letter": {
      "id": "agent-cover-letter",
      "name": "Cover Letter Agent",
      "version": "1.0.0",
      "workflow_name": "📝 Agent: Cover Letter v1.0.0",
      "model": "${MODEL_COVER_LETTER:-anthropic/claude-3-5-sonnet}",
      "fallback_model": "${MODEL_JOB_QUALITY:-google/gemini-flash-1.5}",
      "cover_letter_top_n": "${PIPELINE_COVER_LETTER_TOP_N:-5}",
      "max_retries": 2,
      "timeout_ms": 60000,
      "enabled": true,
      "phase": 5,
      "estimated_tokens": { "min": 1500, "max": 3000 }
    },
    "application_engine": {
      "id": "agent-application-engine",
      "name": "Application Engine Agent",
      "version": "1.0.0",
      "workflow_name": "📤 Agent: Application Engine v1.0.0",
      "model": null,
      "max_retries": 3,
      "timeout_ms": 30000,
      "enabled": true,
      "phase": 5,
      "estimated_tokens": 0
    },
    "notification_engine": {
      "id": "agent-notification-engine",
      "name": "Notification Engine Agent",
      "version": "1.0.0",
      "workflow_name": "🔔 Agent: Notification Engine v1.0.0",
      "model": null,
      "max_retries": 3,
      "timeout_ms": 15000,
      "channels": ["email", "slack", "webhook"],
      "enabled": true,
      "phase": 6,
      "estimated_tokens": 0
    },
    "analytics": {
      "id": "agent-analytics",
      "name": "Analytics Agent",
      "version": "1.0.0",
      "workflow_name": "📊 Agent: Analytics v1.0.0",
      "model": null,
      "max_retries": 1,
      "timeout_ms": 10000,
      "fire_and_forget": true,
      "enabled": true,
      "phase": 6,
      "estimated_tokens": 0
    },
    "memory": {
      "id": "agent-memory",
      "name": "Memory Agent",
      "version": "1.0.0",
      "workflow_name": "🧠 Agent: Memory v1.0.0",
      "model": "${MODEL_EMBEDDING:-openai/text-embedding-3-small}",
      "qdrant_collections": {
        "jobs":      "${QDRANT_COLLECTION_JOBS:-jobs}",
        "resumes":   "${QDRANT_COLLECTION_RESUMES:-resumes}",
        "companies": "${QDRANT_COLLECTION_COMPANIES:-companies}"
      },
      "max_retries": 2,
      "timeout_ms": 10000,
      "enabled": true,
      "phase": 4,
      "estimated_tokens": { "min": 0, "max": 200 }
    }
  }
}
