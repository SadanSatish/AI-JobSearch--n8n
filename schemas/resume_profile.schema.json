{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resume_profile.schema.json",
  "title": "ResumeProfile",
  "description": "Structured resume data extracted by the Resume Intelligence Agent",
  "version": "1.0.0",
  "type": "object",
  "required": ["resume_profile_id", "parsed_at"],
  "properties": {
    "resume_profile_id": { "type": "string" },
    "full_name":    { "type": ["string", "null"] },
    "email":        { "type": ["string", "null"], "format": "email" },
    "phone":        { "type": ["string", "null"] },
    "location":     { "type": ["string", "null"] },
    "summary":      { "type": ["string", "null"] },
    "skills":       { "type": "array", "items": { "type": "string" } },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "company_name": { "type": "string" },
          "title":        { "type": "string" },
          "location":     { "type": ["string", "null"] },
          "start_date":   { "type": ["string", "null"] },
          "end_date":     { "type": ["string", "null"] },
          "is_current":   { "type": "boolean" },
          "description":  { "type": ["string", "null"] },
          "achievements": { "type": "array", "items": { "type": "string" } },
          "skills_used":  { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "institution":    { "type": "string" },
          "degree":         { "type": ["string", "null"] },
          "field_of_study": { "type": ["string", "null"] },
          "start_date":     { "type": ["string", "null"] },
          "end_date":       { "type": ["string", "null"] },
          "gpa":            { "type": ["number", "null"] }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":         { "type": "string" },
          "description":  { "type": ["string", "null"] },
          "url":          { "type": ["string", "null"] },
          "technologies": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "certifications": { "type": "array", "items": { "type": "string" } },
    "languages":      { "type": "array", "items": { "type": "string" } },
    "years_experience":  { "type": ["number", "null"], "minimum": 0 },
    "seniority_level":   { "type": ["string", "null"], "enum": ["junior","mid","senior","lead","executive", null] },
    "parse_confidence":  { "type": "number", "minimum": 0, "maximum": 100 },
    "parsed_at":         { "type": "string", "format": "date-time" }
  }
}
