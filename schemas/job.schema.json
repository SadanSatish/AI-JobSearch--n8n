{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "job.schema.json",
  "title": "Job",
  "description": "Canonical schema for a single job or internship listing throughout the pipeline",
  "version": "1.0.0",
  "type": "object",
  "required": ["listing_id", "source", "title", "company", "listing_type"],
  "properties": {
    "listing_id":      { "type": "string", "description": "Internal unique ID (generated by platform)" },
    "external_id":     { "type": ["string","null"], "description": "Job board's own ID" },
    "source":          { "type": "string", "description": "Job board name: serpapi | adzuna | rapidapi | linkedin | placeholder" },
    "listing_type":    { "type": "string", "enum": ["job", "internship"] },
    "title":           { "type": "string" },
    "company":         { "type": "string" },
    "company_id":      { "type": ["string", "null"], "description": "FK to companies table if verified" },
    "location":        { "type": ["string", "null"] },
    "is_remote":       { "type": "boolean", "default": false },
    "employment_type": { "type": ["string", "null"], "enum": ["full_time","part_time","contract","freelance","internship", null] },
    "experience_level":{ "type": ["string", "null"] },
    "description":     { "type": ["string", "null"] },
    "requirements":    { "type": "array", "items": { "type": "string" } },
    "salary_min":      { "type": ["integer", "null"] },
    "salary_max":      { "type": ["integer", "null"] },
    "salary_currency": { "type": "string", "default": "USD" },
    "apply_url":       { "type": ["string", "null"], "format": "uri" },
    "posted_date":     { "type": ["string", "null"], "format": "date" },
    "fetched_at":      { "type": "string", "format": "date-time" },
    "quality_score":   { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "ghost_score":     { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "is_ghost":        { "type": ["boolean", "null"] },
    "ghost_signals":   { "type": "array", "items": { "type": "string" } },
    "scam_score":      { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "is_scam":         { "type": ["boolean", "null"] },
    "scam_signals":    { "type": "array", "items": { "type": "string" } },
    "duration_months": { "type": ["integer", "null"], "description": "For internships only" },
    "is_paid":         { "type": ["boolean", "null"],  "description": "For internships only" },
    "stipend_amount":  { "type": ["number", "null"],   "description": "For internships only" }
  }
}
