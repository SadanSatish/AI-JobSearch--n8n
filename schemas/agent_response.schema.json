{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_response.schema.json",
  "title": "AgentResponse",
  "description": "Standard envelope that every agent must return. Includes agent_meta for monitoring and the execution_context for pipeline continuity.",
  "version": "1.0.0",
  "type": "object",
  "required": ["execution_context", "status", "agent_meta"],
  "properties": {
    "execution_context": { "$ref": "execution_context.schema.json" },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed", "skipped", "placeholder"],
      "description": "success=completed normally | partial=completed with warnings | failed=agent could not produce output | skipped=bypassed (cache hit or not needed) | placeholder=Phase 2 stub"
    },
    "agent_meta": {
      "type": "object",
      "required": ["agent_id", "agent_version", "execution_id", "duration_ms", "status"],
      "properties": {
        "agent_id":      { "type": "string",           "description": "Canonical agent identifier, e.g. agent-resume-intelligence" },
        "agent_version": { "type": "string",           "description": "Semver version of the agent workflow" },
        "execution_id":  { "type": "string" },
        "model_used":    { "type": ["string", "null"], "description": "The LLM model used, e.g. google/gemini-flash-1.5" },
        "tokens_input":  { "type": "integer",          "minimum": 0 },
        "tokens_output": { "type": "integer",          "minimum": 0 },
        "tokens_total":  { "type": "integer",          "minimum": 0 },
        "duration_ms":   { "type": "integer",          "minimum": 0 },
        "retries":       { "type": "integer",          "minimum": 0, "default": 0 },
        "cache_hit":     { "type": "boolean",          "default": false },
        "status":        { "type": "string",           "enum": ["success","partial","failed","skipped","placeholder"] },
        "error":         { "type": ["string", "null"] },
        "phase":         { "type": ["string", "null"], "description": "Implementation phase note" }
      }
    }
  }
}
