# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_ENV=production
APP_VERSION=1.0.0
APP_LOG_LEVEL=info
DOMAIN=your-domain.com

# =============================================================================
# N8N ORCHESTRATOR
# =============================================================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=super-secret-encryption-key-change-me
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DB_TYPE=postgresdb
DB_NAME=jobsearch
DB_USER=jobsearch_user
DB_PASSWORD=your_secure_db_password
DB_PORT=5432

# =============================================================================
# REDIS (Cache & Queue)
# =============================================================================
REDIS_PASSWORD=your_secure_redis_password
REDIS_PORT=6379

# =============================================================================
# QDRANT (Vector Store)
# =============================================================================
QDRANT_API_KEY=your_secure_qdrant_api_key
QDRANT_PORT=6333
QDRANT_COLLECTION_JOBS=jobs
QDRANT_COLLECTION_RESUMES=resumes
QDRANT_COLLECTION_COMPANIES=companies

# =============================================================================
# AI MODEL API KEYS
# =============================================================================
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GEMINI_API_KEY=your_gemini_key
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
ENCRYPTION_KEY_PII=your_pii_encryption_key
API_BEARER_TOKEN=your_frontend_api_bearer_token
N8N_UI_PASSWORD_HASH=your_caddy_hash_if_applicable
RATE_LIMIT_REQUESTS_PER_MIN=30

# =============================================================================
# STORAGE (S3 - Optional)
# =============================================================================
STORAGE_PROVIDER=local
S3_BUCKET=your_s3_bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_ENDPOINT=your_s3_endpoint

# =============================================================================
# EXTERNAL APIS (Job Boards & Notifications)
# =============================================================================
SERPAPI_KEY=your_serpapi_key
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
RAPIDAPI_KEY=your_rapidapi_key
SLACK_WEBHOOK_URL=your_slack_webhook

# =============================================================================
# EMAIL NOTIFICATIONS (SMTP)
# =============================================================================
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
NOTIFICATION_FROM_EMAIL=noreply@yourdomain.com
