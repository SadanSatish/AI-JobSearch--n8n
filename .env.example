# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Do NOT commit the actual .env file. Use this as a reference.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# n8n Configuration
# -----------------------------------------------------------------------------
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password
N8N_ENCRYPTION_KEY=your_secure_encryption_key

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# CRITICAL: Use the Direct Connection (no -pooler) for n8n.
# -----------------------------------------------------------------------------
DB_POSTGRESDB_HOST=ep-your-db-id.region.aws.neon.tech
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_fresh_db
DB_POSTGRESDB_USER=your_db_user
DB_POSTGRESDB_PASSWORD=your_db_password

# -----------------------------------------------------------------------------
# Cache (Upstash Redis)
# -----------------------------------------------------------------------------
REDIS_HOST=your-redis-endpoint.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# -----------------------------------------------------------------------------
# Vector Store (Qdrant Cloud)
# -----------------------------------------------------------------------------
QDRANT_HOST=your-qdrant-cluster.qdrant.tech
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key

# -----------------------------------------------------------------------------
# External APIs (Placeholders for Future Use)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_key
GEMINI_API_KEY=your_gemini_key
