# =============================================================================
# ENVIRONMENT VARIABLES EXAMPLE
# =============================================================================
# This file is a template. Duplicate it to '.env' and fill in the values.
# NEVER commit your actual '.env' file.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Neon PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=your_postgres_database_url_here?sslmode=require
DB_POSTGRESDB_HOST=your_neon_db_host
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=your_database_name
DB_POSTGRESDB_USER=your_database_user
DB_POSTGRESDB_PASSWORD=your_database_password

# -----------------------------------------------------------------------------
# Redis Configuration (Upstash)
# -----------------------------------------------------------------------------
REDIS_URL=your_redis_url_here
REDIS_HOST_HTTPS=your_upstash_redis_rest_url
REDIS_HOST_TCP=your_upstash_redis_tcp_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_URL=your_qdrant_cluster_url
QDRANT_API_KEY=your_qdrant_api_key

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key
GEMINI_API_KEY=your_google_gemini_api_key

# -----------------------------------------------------------------------------
# n8n Configuration & Security
# -----------------------------------------------------------------------------
N8N_ENCRYPTION_KEY=generate_a_secure_random_key_for_encryption
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here
JWT_SECRET=generate_a_secure_random_jwt_secret
API_BEARER_TOKEN=generate_a_secure_bearer_token
